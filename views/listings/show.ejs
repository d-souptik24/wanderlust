<% layout("/layouts/boilerplate") %>

<div class="show-container">
    <div class="row">
        <div class="col-8 offset-2">
            <div class="listing-header">
                <h1 class="listing-title"><%= listing.title %></h1>
                <div class="listing-meta">
                    <span class="location-badge">
                        <i class="fa-solid fa-location-dot"></i>
                        <%= listing.location %>, <%= listing.country %>
                    </span>
                </div>
            </div>

            <div class="listing-image-container">
                <img src="<%= listing.image.url %>" class="listing-image" alt="<%= listing.title %>">
            </div>

            <div class="listing-details-section">
                <div class="row">
                    <div class="col-md-7">
                        <div class="details-card">
                            <h3 class="details-heading">About this property</h3>
                            <p class="listing-description"><%= listing.description %></p>
                        </div>
                    </div>

                    <div class="col-md-5">
                        <div class="price-card">
                            <div class="price-display">
                                <span class="currency">&#x20B9;</span>
                                <span class="price-amount"><%= listing.price.toLocaleString("en-IN") %></span>
                                <span class="price-period">/night</span>
                            </div>
                            <hr>
                            <div class="action-buttons">
                                <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary w-100 mb-2">
                                    <i class="fa-solid fa-pen-to-square"></i> Edit Listing
                                </a>
                                <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" style="display:inline;" class="w-100">
                                    <button type="submit" class="btn btn-danger w-100" onclick="return confirm('Are you sure you want to delete this listing?');">
                                        <i class="fa-solid fa-trash"></i> Delete Listing
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="back-button-section">
                <a href="/listings" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left"></i> Back to All Listings
                </a>
            </div>
        </div>
    </div>
</div>
